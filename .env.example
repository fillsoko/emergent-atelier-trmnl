# Emergent Atelier — environment template
# Copy to .env and fill in values before starting the server.
#
# Generate CYCLE_SECRET:
#   openssl rand -hex 32
#
# Generate TRMNL_STORE_KEY:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Get TRMNL_CLIENT_ID + TRMNL_CLIENT_SECRET from:
#   https://usetrmnl.com/plugins/my/<id>/edit  (after creating your plugin)

# ── Required ─────────────────────────────────────────────────────────────────

# Secret used to authenticate internal cycle-trigger webhook (32+ hex chars)
CYCLE_SECRET=

# TRMNL marketplace app credentials
TRMNL_CLIENT_ID=
TRMNL_CLIENT_SECRET=

# Public base URL of this server — no trailing slash
# e.g. https://emergent-atelier.filipsokolowski.com
TRMNL_PUBLIC_URL=

# Fernet key for encrypting the installation store (user PII at rest)
TRMNL_STORE_KEY=
