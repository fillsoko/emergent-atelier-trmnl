# Emergent Atelier — environment template
# Copy to .env and fill in values before starting the server.
#
# Generate CYCLE_SECRET:
#   openssl rand -hex 32
#
# Generate TRMNL_STORE_KEY:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Generate CADDY_PROXY_SECRET:
#   openssl rand -hex 32
#
# Get TRMNL_CLIENT_ID + TRMNL_CLIENT_SECRET from:
#   https://usetrmnl.com/plugins/my/<id>/edit  (after creating your plugin)

# ── Required ─────────────────────────────────────────────────────────────────

# Secret used to authenticate internal cycle-trigger webhook (32+ hex chars)
CYCLE_SECRET=

# TRMNL marketplace app credentials
TRMNL_CLIENT_ID=
TRMNL_CLIENT_SECRET=

# Public base URL of this server — no trailing slash
# e.g. https://emergent-atelier.filipsokolowski.com
TRMNL_PUBLIC_URL=

# Fernet key for encrypting the installation store (user PII at rest). REQUIRED.
TRMNL_STORE_KEY=

# ── Vote rate-limit security (SOK-246) ──────────────────────────────────────

# Salt for IP address hashing in votes.db. REQUIRED — prevents pre-computation
# attacks against the vote rate limiter. Must not be empty.
# Generate with: openssl rand -hex 32
VOTE_IP_SALT=

# ── Dashboard auth (SOK-221) ─────────────────────────────────────────────────

# Optional HTTP Basic Auth password for the dashboard and internal API
# endpoints (/api/status, /api/history, /api/agents).
# Any username is accepted; the password must match this value.
# Recommended in production for defense-in-depth beyond the proxy secret.
#
# Generate with: openssl rand -hex 32
DASHBOARD_SECRET=

# ── Proxy security (SOK-202) ─────────────────────────────────────────────────

# Shared secret between Caddy and the app.
# Must match the value exported as CADDY_PROXY_SECRET when loading Caddy.
CADDY_PROXY_SECRET=

# Set to "true" to reject requests that did not arrive via Caddy.
# REQUIRED in production. CADDY_PROXY_SECRET must also be set when true.
REQUIRE_PROXY_SECRET=true
